{
  "version": 2,
  "builds": [
    {
      "src": "backend/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/server.js"
    },
    {
      "src": "/config.js",
      "dest": "config.js"
    },
    {
      "src": "/(.*)",
      "dest": "index.html"
    }
  ]
}
